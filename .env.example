# =============================================================================
# .env.example — Plantilla de variables de entorno
# Copiar a .env y completar con valores reales.
# NUNCA hacer commit del archivo .env con valores reales.
# =============================================================================

# ------------------------------------------------------------------------------
# DJANGO CORE
# ------------------------------------------------------------------------------
# Genera una clave segura con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=tu-clave-secreta-generada-aqui

# En producción debe ser False SIEMPRE
DEBUG=False

# Hosts permitidos (separados por coma, sin espacios)
# LOCAL: localhost,127.0.0.1
# AZURE: localhost,127.0.0.1,mi-app.azurewebsites.net
ALLOWED_HOSTS=localhost,127.0.0.1,mi-app.azurewebsites.net

# Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# BASE DE DATOS — PostgreSQL (Azure Database for PostgreSQL Flexible Server)
# Dejar DB_HOSTNAME vacío para usar SQLite en desarrollo local
# En Azure: Obtén estos valores de la página "Connection strings" en el Azure Portal
# ------------------------------------------------------------------------------
# Para DESARROLLO (usa SQLite): Dejar DB_HOSTNAME vacío o comentado
# DB_HOSTNAME=

# Para PRODUCCIÓN (Azure PostgreSQL):
DB_HOSTNAME=mi-servidor.postgres.database.azure.com
DB_NAME=dental_db
DB_USER=mi_usuario_db
DB_PASSWORD=mi_contrasena_super_segura
DB_PORT=5432
